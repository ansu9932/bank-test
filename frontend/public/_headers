# Cloudflare Pages response headers (replaces the Apache .htaccess header rules).
# NOTE: each header value must be on a SINGLE line.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self), payment=(self)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://checkout.razorpay.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://api.alisterbank.online https://api.qrserver.com; media-src 'self' blob: https://api.alisterbank.online; connect-src 'self' https://api.alisterbank.online https://api.razorpay.com https://checkout.razorpay.com https://rzp.io https://cloudflareinsights.com; frame-src 'self' https://api.razorpay.com https://checkout.razorpay.com https://rzp.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Long-lived immutable cache for content-hashed build assets.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

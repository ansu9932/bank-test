

# ─── FX / Currency ────────────────────────────────────────────────────────────
# Deposits are entered in USD but the UPI/Razorpay rail settles in INR. The live
# USD→INR rate is fetched from a public FX feed; this value is used ONLY as a
# fallback when that feed is unreachable. Optional (defaults to 90).
USD_INR_FALLBACK_RATE=90


# ─── Email / SMTP (Brevo transactional relay) ─────────────────────────────────
# Brevo (smtp-relay.brevo.com) is used for all transactional email.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
# Your Brevo SMTP login (looks like 8a24d3001@smtp-brevo.com)
SMTP_USER=8a24d3001@smtp-brevo.com
# Your Brevo SMTP KEY (NOT your account password). Create it in Brevo →
# SMTP & API → SMTP. Keep this secret; never commit it.
SMTP_PASS=your-brevo-smtp-key

# The visible "From" address. MUST be a sender you VERIFIED in Brevo
# (Brevo → Senders, Domains & Dedicated IPs). It must NOT be the SMTP login.
EMAIL_FROM=no-reply@alisterbank.online
EMAIL_FROM_NAME=Alister Bank

# Optional SMTP pool tuning (sensible defaults applied if omitted).
# SMTP_MAX_CONNECTIONS=5
# SMTP_MAX_MESSAGES=100
# SMTP_RATE_LIMIT=10

# ─── Transactional SMS (Brevo) ───────────────────────────────────────────────
# Used for the SWIFT approval notification sent to the customer's mobile.
# Create/rotate this in Brevo → SMTP & API → API Keys (v3 key, starts "xkeysib-").
BREVO_API_KEY=your-brevo-v3-api-key
# Approved alphanumeric sender ID (max 11 chars). For India this must be a
# DLT-registered header, e.g. ALSTER. Requires SMS credits on the Brevo account.
BREVO_SMS_SENDER=ALSTER
# Default country code applied to bare 10-digit numbers (91 = India).
# SMS_DEFAULT_COUNTRY_CODE=91
